generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  password  String?
  name      String
  role      String   @default("user") // admin, umpire, player
  player    Player?
}

model Player {
  id        String   @id @default(uuid())
  name      String
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  
  // Relations for tracking stats
  ballsFaced Delivery[] @relation("Batter")
  ballsBowled Delivery[] @relation("Bowler")
  matches     MatchPlayer[]
}

model Match {
  id            String   @id @default(uuid())
  teamA         String
  teamB         String
  mode          String   @default("quick") // quick, pro
  overs         Int
  includeExtras Boolean  @default(true)
  status        String   @default("live") // live, completed
  target        Int?
  umpirePin     String?
  bowlerOverLimit Int    @default(0) // 0 means no limit
  winningTeam   String?
  createdAt     DateTime @default(now())
  innings       Inning[]
  players       MatchPlayer[]
}

model MatchPlayer {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  team      String   // A or B
}

model Inning {
  id           String   @id @default(uuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id])
  battingTeam  String
  totalRuns    Int      @default(0)
  totalWickets Int      @default(0)
  status       String   @default("active") // active, completed
  createdAt    DateTime @default(now())
  
  // Professional Field State
  strikerId       String?
  nonStrikerId    String?
  currentBowlerId String?

  deliveries   Delivery[]
}

model Delivery {
  id          String   @id @default(uuid())
  inningId    String
  inning      Inning   @relation(fields: [inningId], references: [id])
  
  // Performance Tracking
  batterId    String?
  batter      Player?  @relation("Batter", fields: [batterId], references: [id])
  bowlerId    String?
  bowler      Player?  @relation("Bowler", fields: [bowlerId], references: [id])

  overNumber  Int
  ballNumber  Int
  runs        Int      @default(0)
  extras      Int      @default(0)
  extraType   String   @default("none") // wide, no-ball, leg-bye
  wicketType  String   @default("none") // bowled, caught, lbw, runout
  pitchX      Float?
  pitchY      Float?
  createdAt   DateTime @default(now())
}
